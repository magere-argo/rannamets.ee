---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  nav?: NavItem[];
}

const defaultNav: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Right Things Nailed', href: '/right-things-nailed/' },
  { label: 'Execution Playbook', href: '/execution-playbook/' },
  { label: 'Coaching & Mentoring', href: '/coaching-mentoring/' },
  { label: 'Owner-Sponsor Cohort', href: '/owner-sponsor-cohort/' },
  { label: 'Advisory Board Seat', href: '/advisory-board-seat/' },
  { label: 'Insights', href: '/insights/' },
  { label: 'Contact', href: '/contact/' },
];

const { nav = defaultNav } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__wordmark" href="/">ARGO RANNAMETS</a>
    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {nav.map((item) => (
          <li class="site-nav__item">
            <a
              href={item.href}
              class:list={[
                'site-nav__link',
                currentPath === item.href && 'site-nav__link--active',
              ]}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg);
    border-bottom: var(--hairline) solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-height: 5rem;
    padding-block: var(--space-4);
  }

  .site-header__wordmark {
    font-family: var(--font-heading);
    font-weight: var(--weight-heavy);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wider);
    color: var(--color-navy);
    text-decoration: none;
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .site-nav__item { margin: 0; }

  .site-nav__link {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 2px solid transparent;
    transition: color var(--dur) var(--ease),
                border-color var(--dur) var(--ease);
  }

  .site-nav__link:hover {
    color: var(--color-navy);
  }

  .site-nav__link--active {
    color: var(--color-navy);
    border-bottom-color: var(--color-copper);
  }

  @media (max-width: 640px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .site-nav__list {
      gap: var(--space-4);
    }
  }
</style>
