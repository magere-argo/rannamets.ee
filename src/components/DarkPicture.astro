---
type Align = 'left' | 'center';
type Size = 'default' | 'hero';

interface Props {
  question: string;
  align?: Align;
  size?: Size;
  attribution?: string;
  id?: string;
}

const {
  question,
  align = 'left',
  size = 'default',
  attribution,
  id,
} = Astro.props;
---

<section
  id={id}
  class:list={[
    'dp',
    `dp--align-${align}`,
    size === 'hero' && 'dp--hero',
  ]}
  aria-label="Provocation"
>
  <div class="dp__inner">
    <span class="dp__rule" aria-hidden="true"></span>
    <p class="dp__question">{question}</p>
    {attribution && <p class="dp__attribution">{attribution}</p>}
  </div>
</section>

<style>
  .dp {
    background: var(--color-navy);
    color: var(--color-on-dark);
    padding-block: var(--section-py-lg);
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
  }

  .dp__inner {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .dp--align-center .dp__inner {
    text-align: center;
  }

  .dp__rule {
    display: block;
    width: 4rem;
    height: var(--rule-thick);
    background: var(--color-copper);
    margin-bottom: var(--space-10);
  }

  .dp--align-center .dp__rule {
    margin-inline: auto;
  }

  .dp__question {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: var(--weight-bold);
    color: var(--color-on-dark);
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }

  .dp--align-center .dp__question {
    margin-inline: auto;
  }

  .dp--hero .dp__question {
    font-size: var(--text-6xl);
    font-weight: var(--weight-heavy);
    max-width: 20ch;
  }

  .dp__attribution {
    margin: var(--space-8) 0 0;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-on-dark-muted);
  }
</style>
