---
/*
 * Pullquote — Argo's voice moments. Brief §3.7.
 *
 * Max 1-2 per page. Lives inside a section's content flow (not a
 * full section break). Tight density: rules sit 16-24px from the
 * quote text, not floating in acres of whitespace.
 *
 * Two APIs:
 *  - quote prop with a string (HTML-allowed via set:html so .accent
 *    spans work) plus optional attribution
 *  - slot for richer markup
 */

interface Props {
  quote?: string;
  attribution?: string;
  id?: string;
  class?: string;
}

const { quote, attribution, id, class: className = '' } = Astro.props;

const hasSlot = Astro.slots.has('default');
---

<figure id={id} class:list={['pullquote', className]}>
  <hr class="pullquote__rule" aria-hidden="true" />
  <blockquote class="pullquote__quote">
    {hasSlot ? (
      <slot />
    ) : quote ? (
      <p set:html={quote} />
    ) : null}
  </blockquote>
  <hr class="pullquote__rule" aria-hidden="true" />
  {attribution && <figcaption class="pullquote__attribution">{attribution}</figcaption>}
</figure>

<style>
  .pullquote {
    margin: var(--space-16) auto;        /* 64 px top/bottom within section */
    max-width: var(--container-quote);   /* 800 px */
    padding: 0;
  }

  @media (min-width: 1024px) {
    .pullquote {
      margin-block: var(--space-24);     /* 96 px on wider viewports */
    }
  }

  .pullquote__rule {
    width: 100%;
    height: 1px;
    background: var(--color-copper);
    border: 0;
    margin: 0;
  }

  .pullquote__quote {
    margin: 0;
    padding: var(--space-6) 0; /* 24 px breathing space between rule and text — tight per §3.7 */
  }

  .pullquote__quote :global(p) {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-lead);       /* 19-24 px desktop / mobile clamp */
    line-height: var(--lh-lead);
    font-weight: var(--weight-regular);
    color: var(--color-slate-600);     /* softer to distinguish voice from heading */
    margin: 0 0 var(--space-4) 0;
  }

  .pullquote__quote :global(p:last-child) {
    margin-bottom: 0;
  }

  .pullquote__quote :global(.accent) {
    color: var(--color-copper);
    font-style: italic;
  }

  .pullquote__attribution {
    font-family: var(--font-heading);
    font-size: var(--text-meta);
    color: var(--color-slate-400);
    margin-top: var(--space-3);
    letter-spacing: var(--tracking-button);
  }
</style>
