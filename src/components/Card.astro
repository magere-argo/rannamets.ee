---
interface Props {
  title: string;
  href?: string;
  eyebrow?: string;
}

const { title, href, eyebrow } = Astro.props;
const Wrapper = href ? 'a' : 'article';
---

<Wrapper class:list={['card', { 'card--link': !!href }]} {...(href ? { href } : {})}>
  {eyebrow && <span class="card__eyebrow">{eyebrow}</span>}
  <h3 class="card__title">{title}</h3>
  <div class="card__body"><slot /></div>
  {href && <span class="card__cta">Read more →</span>}
</Wrapper>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-top: var(--rule-thick) solid var(--color-copper);
    padding: var(--space-8) var(--space-6) var(--space-6);
    color: var(--color-text);
    text-decoration: none;
    transition: background-color var(--dur) var(--ease),
                border-color var(--dur) var(--ease),
                transform var(--dur) var(--ease);
  }

  .card--link:hover {
    background: var(--color-bg-raised);
  }

  .card__eyebrow {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: var(--space-3);
  }

  .card__title {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--color-navy);
    margin: 0 0 var(--space-4) 0;
    font-weight: var(--weight-bold);
  }

  .card__body {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    flex: 1 1 auto;
  }

  .card__cta {
    display: inline-block;
    margin-top: var(--space-6);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-steel);
  }

  .card--link:hover .card__cta {
    color: var(--color-copper);
  }
</style>
