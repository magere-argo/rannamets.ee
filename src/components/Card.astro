---
/*
 * Card — offering tile / related-content block. Brief §3.8.
 *
 * Background stone (default) or white. No drop shadow. Optional
 * 1-2 px slate-200 border. Border-radius 0-4 px.
 */

type Surface = 'stone' | 'white';

interface Props {
  title: string;
  href?: string;
  eyebrow?: string;
  surface?: Surface;
}

const { title, href, eyebrow, surface = 'stone' } = Astro.props;
const Wrapper = href ? 'a' : 'article';
---

<Wrapper
  class:list={['card', `card--${surface}`, { 'card--link': !!href }]}
  {...(href ? { href } : {})}
>
  {eyebrow && <span class="card__eyebrow">{eyebrow}</span>}
  <h3 class="card__title">{title}</h3>
  <div class="card__body"><slot /></div>
  {href && <span class="card__cta" aria-hidden="true">Read more →</span>}
</Wrapper>

<style>
  .card {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);            /* 32 px */
    border-radius: 2px;
    text-decoration: none;
    color: var(--color-slate-600);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  @media (min-width: 1024px) {
    .card {
      padding: var(--space-12);         /* 48 px on wider viewports */
    }
  }

  .card--stone { background: var(--color-bg-raised); }
  .card--white { background: var(--color-white); border: 1px solid var(--color-slate-200); }

  .card--link:hover {
    background: color-mix(in srgb, var(--color-bg-raised) 80%, var(--color-copper) 6%);
  }

  .card__eyebrow {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: var(--space-3);      /* 12 px */
  }

  .card__title {
    font-size: var(--text-h3);          /* 20-26 px */
    line-height: var(--lh-h3);
    color: var(--color-slate-900);
    margin: 0 0 var(--space-3) 0;       /* 12 px to body */
    font-weight: var(--weight-semibold);
  }

  .card__body {
    color: var(--color-slate-600);
    font-size: var(--text-body);
    line-height: var(--lh-body);
    flex: 1 1 auto;
  }

  .card__body :global(.accent) {
    color: var(--color-copper);
  }

  .card__cta {
    display: inline-block;
    margin-top: var(--space-6);
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-button);
    color: var(--color-steel);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .card--link:hover .card__cta {
    color: var(--color-copper);
  }
</style>
