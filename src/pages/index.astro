---
import Base from '../layouts/Base.astro';
import DarkPicture from '../components/DarkPicture.astro';
import Section from '../components/Section.astro';
---

<Base
  title="Argo Rannamets"
  description="Strategy Execution Leader as a Service. Operator, not observer. Installer, not trainer. 25 years across 100+ companies in 8 countries."
>
  <DarkPicture
    size="hero"
    question="How many of your strategic priorities will survive contact with next quarter's emergencies?"
  />

  <Section>
    <div class="prose">
      <p class="lead">
        This is a placeholder homepage for the launch-v1 rebuild. The design
        system is in place and ready for content. See <a href="/demo/">/demo</a>
        for every component used in context.
      </p>
    </div>
  </Section>
</Base>
