---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import DarkPicture from '../components/DarkPicture.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
---

<Base
  title="Design system demo"
  description="Internal preview of the Argo Rannamets design system. Placeholder content only."
  noindex={true}
>
  <!-- Hero DarkPicture — the signature element. Real provocation per brief. -->
  <DarkPicture
    size="hero"
    question="How many of your strategic priorities will survive contact with next quarter's emergencies?"
    attribution="From the Dark Picture library"
  />

  <!-- Typography scale — neutral specimen text only -->
  <Section>
    <span class="eyebrow">[Eyebrow label]</span>
    <hr class="rule" />
    <h2>[Section heading — copy pending]</h2>
    <div class="prose">
      <p class="lead">
        [Lead paragraph — copy pending. Lorem ipsum dolor sit amet, consectetur
        adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore
        magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.]
      </p>
      <p>
        [Body paragraph — copy pending. Lorem ipsum dolor sit amet, consectetur
        adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore
        magna aliqua. Inline links such as <a href="#">this example</a> stay
        restrained, underlined for affordance and copper-tinted on hover.
        <strong>Strong text</strong> carries semantic emphasis without shouting;
        <em>italics</em> mark terminology and titles.]
      </p>
      <p>
        [Body paragraph — copy pending. Duis aute irure dolor in reprehenderit
        in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
        Excepteur sint occaecat cupidatat non proident, sunt in culpa qui
        officia deserunt mollit anim id est laborum.]
      </p>
    </div>

    <hr class="rule" />

    <h1>H1 — The quick brown fox jumps over the lazy dog</h1>
    <h2>H2 — The quick brown fox jumps over the lazy dog</h2>
    <h3>H3 — The quick brown fox jumps over the lazy dog</h3>
    <h4>H4 — The quick brown fox jumps over the lazy dog</h4>
    <h5>H5 — The quick brown fox jumps over the lazy dog</h5>
    <h6>H6 — Eyebrow / category label</h6>
  </Section>

  <!-- Buttons -->
  <Section>
    <span class="eyebrow">[Eyebrow label]</span>
    <hr class="rule" />
    <h2>Buttons — primary and secondary</h2>
    <div class="prose">
      <p>[Body paragraph — copy pending.]</p>
    </div>
    <div class="demo-button-row">
      <Button href="/contact/">[Primary CTA]</Button>
      <Button href="#" variant="secondary">[Secondary CTA]</Button>
    </div>
  </Section>

  <!-- DarkPicture default variant — placeholder only -->
  <DarkPicture
    question="[Provocation question — copy pending]"
  />

  <!-- Cards -->
  <Section>
    <span class="eyebrow">[Eyebrow label]</span>
    <hr class="rule" />
    <h2>Cards — typographic offering tiles</h2>
    <div class="card-grid">
      <Card href="#" title="[Card title]" eyebrow="[Eyebrow]">
        [Card body — copy pending. Lorem ipsum dolor sit amet, consectetur
        adipiscing elit, sed do eiusmod tempor incididunt.]
      </Card>
      <Card href="#" title="[Card title]" eyebrow="[Eyebrow]">
        [Card body — copy pending. Ut enim ad minim veniam, quis nostrud
        exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.]
      </Card>
      <Card href="#" title="[Card title]" eyebrow="[Eyebrow]">
        [Card body — copy pending. Duis aute irure dolor in reprehenderit in
        voluptate velit esse cillum dolore eu fugiat nulla pariatur.]
      </Card>
    </div>
  </Section>

  <!-- Section variants -->
  <Section variant="dark" size="lg">
    <span class="eyebrow">[Eyebrow label]</span>
    <hr class="rule" />
    <h2>Dark Section variant — multi-element layouts on navy</h2>
    <div class="prose">
      <p>
        [Body paragraph — copy pending. Lorem ipsum dolor sit amet, consectetur
        adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore
        magna aliqua.]
      </p>
      <p>
        [Body paragraph — copy pending. The dark Section is distinct from the
        DarkPicture. Use Section dark for opening provocations that need
        supporting copy. Use DarkPicture for the single-question hero moment.]
      </p>
    </div>
  </Section>

  <Section>
    <span class="eyebrow">[Eyebrow label]</span>
    <hr class="rule" />
    <h2>Light Section variant — default surface on warm off-white</h2>
    <div class="prose">
      <p>
        [Body paragraph — copy pending. The default surface is
        <code>#FAFAF7</code> — warm enough to read as editorial, cold enough
        to keep the navy-and-copper palette in tension. Pure white reads as
        clinical and brochure-like; we avoid it.]
      </p>
    </div>
  </Section>

  <!-- DarkPicture centered variant — placeholder only -->
  <DarkPicture
    align="center"
    question="[Provocation question — copy pending]"
  />
</Base>

<style>
  .demo-button-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  code {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    font-size: 0.95em;
    background: var(--color-bg-raised);
    padding: 0.05em 0.35em;
    border-radius: 2px;
  }
</style>
